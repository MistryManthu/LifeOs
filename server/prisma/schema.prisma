generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────────────────────
// LAYER 1: IDENTITY
// The core user + their Human Blueprint
// ─────────────────────────────────────────────────────────────

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  password  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // One user has one evolving blueprint
  blueprint     HumanBlueprint?
  goals         Goal[]
  lifeEvents    LifeEvent[]
  dailyLogs     DailyLog[]
  weeklyReviews WeeklyReview[]
  memories      Memory[]
  patterns      Pattern[]
  agentInsights AgentInsight[]
  behaviorLogs  BehaviorLog[]
}

// The Human Blueprint — collected during onboarding
// This is the "kernel" of HumanOS. Everything else references this.
model HumanBlueprint {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // --- Identity ---
  ageRange   String? // "18-24", "25-30", "31-40" etc.
  occupation String?
  location   String?

  // --- Roles ---
  currentRole  String   // "Software Engineer"
  futureRole   String   // "Founder / Entrepreneur"
  lifeRoles    String[] // ["Son", "Gym Person", "App Builder", "Partner"]

  // --- Responsibilities ---
  responsibilities String[] // ["Parents", "Younger sibling", "Self"]

  // --- Goals (high level, time-horizoned) ---
  oneYearGoal  String?
  fiveYearGoal String?
  lifetimeGoal String?

  // --- Constraints ---
  constraints String[] // ["Limited time", "Limited capital", "Full-time job"]

  // --- Values (what they say matters) ---
  declaredValues String[] // ["Freedom", "Family", "Health", "Wealth", "Growth"]

  // --- Psychology ---
  riskTolerance  RiskTolerance @default(MEDIUM)
  learningStyle  LearningStyle @default(VISUAL)
  workStyle      WorkStyle     @default(MIXED)

  // --- Sacrifices & Trade-offs ---
  willingToSacrifice String[] // ["Weekend time", "Social events temporarily"]
  notWillingToSacrifice String[] // ["Family dinners", "Gym time"]

  // --- Strengths & Weaknesses (self-reported initially) ---
  selfReportedStrengths  String[] // ["Persistence", "Tech skills"]
  selfReportedWeaknesses String[] // ["Consistency", "Overthinking"]

  // --- Life Story (the secret weapon) ---
  lifeStoryEvents String[] // ["Lost my father at 22", "Failed my first startup", "Got job at Alten"]

  // --- Snapshot generated by Guardian on completion ---
  guardianSnapshot String? // AI-generated "Life Snapshot" after onboarding

  // --- Blueprint completeness ---
  isComplete    Boolean  @default(false)
  completedAt   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─────────────────────────────────────────────────────────────
// LAYER 2: GOALS
// Structured, domain-specific, time-bound goals
// ─────────────────────────────────────────────────────────────

model Goal {
  id          String     @id @default(cuid())
  userId      String
  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  title       String
  description String?
  domain      Domain
  priority    Priority   @default(MEDIUM)
  status      GoalStatus @default(ACTIVE)

  // Time horizon
  targetDate  DateTime?
  quarter     Int?  // 1-4
  year        Int?

  // Progress tracking
  progressPct Int @default(0) // 0-100

  // Guardian-detected bottleneck for this goal
  currentBottleneck   String?
  bottleneckCategory  BottleneckCategory?
  bottleneckUpdatedAt DateTime?

  dailyLogs     DailyLog[]   @relation("DailyLogGoals")
  agentInsights AgentInsight[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─────────────────────────────────────────────────────────────
// LAYER 3: DAILY ENGINE
// The heartbeat of HumanOS — morning + evening check-ins
// ─────────────────────────────────────────────────────────────

model DailyLog {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  date   DateTime @default(now())

  // --- Morning check-in ---
  morningCompleted Boolean @default(false)
  mainObjective    String?   // "What's your main objective today?"
  availableHours   Float?    // "How many hours do you have?"
  topChallenge     String?   // "What's your biggest challenge today?"
  energyLevel      Int?      // 1-10
  mood             String?   // "focused", "anxious", "motivated", "drained"

  // Guardian's morning suggestion (generated after morning check-in)
  guardianMorningSuggestion String?
  suggestedPriorities       String[] // AI-suggested top 3 for today

  // --- Evening check-in ---
  eveningCompleted  Boolean @default(false)
  completedWork     String?  // "What did you actually complete?"
  blockers          String?  // "What blocked you?"
  eveningEnergy     Int?     // 1-10
  eveningReflection String?  // Free text

  // Goals this day was linked to
  goals Goal[] @relation("DailyLogGoals")

  // Guardian processed this log and updated memory
  memoryExtracted Boolean @default(false)

  createdAt DateTime @default(now())
}

// ─────────────────────────────────────────────────────────────
// LAYER 4: MEMORY GRAPH
// The moat — structured, typed, persistent memory
// This is what makes HumanOS different from every other app
// ─────────────────────────────────────────────────────────────

model Memory {
  id     String     @id @default(cuid())
  userId String
  user   User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  type      MemoryType
  content   String     // The actual memory text
  importance Int       @default(5) // 1-10, affects retrieval priority

  // Source of this memory
  sourceType  MemorySource // where did this come from?
  sourceId    String?      // ID of the DailyLog, WeeklyReview, etc.

  // Expiry (working memory expires, permanent doesn't)
  expiresAt DateTime?
  isActive  Boolean @default(true)

  // Evidence for pattern memories
  evidence String[] // what specific data points support this memory

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─────────────────────────────────────────────────────────────
// LAYER 5: BEHAVIOR TRACKING
// Stated values vs observed behavior — the gap detector
// ─────────────────────────────────────────────────────────────

model BehaviorLog {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  domain      Domain
  action      String   // "Skipped gym", "Worked on side project", "Called parents"
  alignedWith String[] // Which declared values this aligns with
  date        DateTime @default(now())
}

// Detected pattern — Guardian builds these over time
model Pattern {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  title       String  // "Avoids sales-related tasks"
  description String  // Detailed pattern description
  domain      Domain?

  // Confidence builds as evidence accumulates
  confidence  Int     @default(30) // 0-100
  evidence    String[] // Specific data points

  // Stated vs observed gap
  isValueGap       Boolean @default(false)
  declaredValue    String? // "Health is my priority"
  observedBehavior String? // "Skipped gym 8 out of 10 days"

  isActive  Boolean @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─────────────────────────────────────────────────────────────
// LAYER 6: LIFE EVENTS
// Timeline — major events that shaped the person
// ─────────────────────────────────────────────────────────────

model LifeEvent {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  title       String
  description String?
  eventDate   DateTime
  domain      Domain?
  impactScore Int?    // -10 to +10 (negative = hardship, positive = milestone)
  tags        String[] // ["Career", "Loss", "Achievement", "Relationship"]

  createdAt DateTime @default(now())
}

// ─────────────────────────────────────────────────────────────
// LAYER 7: GUARDIAN PIPELINE OUTPUT
// Every Guardian reasoning cycle produces an AgentInsight
// ─────────────────────────────────────────────────────────────

model AgentInsight {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // What triggered this insight
  trigger     InsightTrigger // DAILY_CHECKIN | WEEKLY_REVIEW | GOAL_UPDATE | PATTERN_DETECTED

  // The Guardian's output
  currentFocus      String?   // "Launch food truck"
  bottleneck        String?   // "No supplier shortlist yet"
  bottleneckCategory BottleneckCategory?
  recommendation    String?   // "Contact 5 suppliers this week"
  nextBestAction    String?   // "Create a supplier spreadsheet today"
  reasoning         String?   // Why the Guardian concluded this (transparency principle)

  // Full Guardian response
  fullResponse String?

  // Which goal this insight relates to
  goalId String?
  goal   Goal?   @relation(fields: [goalId], references: [id])

  // Did the user act on this?
  userActed    Boolean?
  userFeedback String?  // "This was helpful" / "Not relevant"

  createdAt DateTime @default(now())
}

// ─────────────────────────────────────────────────────────────
// LAYER 8: WEEKLY REVIEW
// AI-generated every Sunday, stores structured + raw output
// ─────────────────────────────────────────────────────────────

model WeeklyReview {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  weekStart DateTime
  weekEnd   DateTime

  // Structured outputs
  wins             String[]
  missedOpportunities String[]
  emergingPatterns String[]
  nextWeekFocus    String[]

  // Domain scores this week (0-100 per domain)
  domainScores Json // { "WORK": 75, "HEALTH": 40, "MONEY": 60, ... }

  // Guardian's biggest bottleneck finding for the week
  weeklyBottleneck         String?
  weeklyBottleneckCategory BottleneckCategory?

  // Full AI-generated review text
  fullReview String?

  // User's response
  userReflection String?
  userRating     Int?    // 1-5, did this review feel accurate?

  createdAt DateTime @default(now())
}

// ─────────────────────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────────────────────

enum Domain {
  WORK
  HEALTH
  MONEY
  GROWTH
  RELATIONSHIPS
  HOME
  BUSINESS
}

enum GoalStatus {
  ACTIVE
  COMPLETED
  PAUSED
  DROPPED
}

enum Priority {
  HIGH
  MEDIUM
  LOW
}

enum RiskTolerance {
  LOW
  MEDIUM
  HIGH
}

enum LearningStyle {
  VISUAL
  READING
  HANDS_ON
  AUDIO
}

enum WorkStyle {
  MORNING_PERSON
  NIGHT_OWL
  MIXED
}

enum MemoryType {
  // Permanent — never expires
  CORE_VALUE     // "Values financial freedom above status"
  MAJOR_GOAL     // "Wants to launch a SaaS by Dec 2026"
  LIFE_EVENT     // "Father passed away in 2019"
  STRENGTH       // "Highly persistent, doesn't give up"
  WEAKNESS       // "Struggles with context switching"

  // Working — expires after project/period ends
  CURRENT_PROJECT   // "Building LifeOS app"
  CURRENT_PRIORITY  // "This week: finish schema design"

  // Pattern — built over time from behavior
  HABIT         // "Works best after 9 PM"
  TENDENCY      // "Avoids tasks involving sales/cold outreach"
  OBSTACLE      // "Repeatedly abandons projects at 60% completion"

  // Reflection — from weekly reviews
  LESSON        // "Learned: breaking tasks smaller helps completion"
  MILESTONE     // "Completed first working MVP"
}

enum MemorySource {
  ONBOARDING
  DAILY_CHECKIN
  WEEKLY_REVIEW
  LIFE_EVENT
  GOAL_UPDATE
  GUARDIAN_INFERENCE  // Guardian detected this, user didn't explicitly say it
  USER_CORRECTION     // User said "that's wrong, actually..."
}

enum BottleneckCategory {
  TIME
  MONEY
  KNOWLEDGE
  FEAR
  HEALTH
  RELATIONSHIPS
  EXECUTION
  CLARITY       // Don't know what to do next
  MOTIVATION
}

enum InsightTrigger {
  MORNING_CHECKIN
  EVENING_CHECKIN
  WEEKLY_REVIEW
  GOAL_UPDATE
  PATTERN_DETECTED
  USER_INITIATED  // User asked Guardian a question
}
